# ─────────────────────────────────────────────────────────────────────────
# Telegram Assistant — environment template.  Copy to `.env` and fill in.
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────

# ── Telegram BOT (control panel) ── from @BotFather ──────────────────────
BOT_TOKEN=123456:ABC-DEF...
# Your own Telegram numeric user id (only this chat may command the bot).
# Get it from @userinfobot.
OWNER_CHAT_ID=123456789

# ── Telegram USERBOT (your account) ── from https://my.telegram.org ──────
API_ID=1234567
API_HASH=0123456789abcdef0123456789abcdef
# Generated once locally:  python -m scripts.generate_session
# Paste the printed StringSession here. Treat as a top-level secret.
TELETHON_SESSION=

# ── NLU brain — which AI understands commands ────────────────────────────
# "gemini" (Google, free tier) or "anthropic" (Claude, paid).
LLM_PROVIDER=gemini

# Gemini (FREE) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Voice: Gemini's built-in text-to-speech (FREE, no ElevenLabs/cloning needed).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Prebuilt voice. Male: Charon, Puck, Fenrir, Orus, Enceladus, Iapetus.
# Female: Kore, Aoede, Leda, Callirrhoe, Autonoe.
GEMINI_TTS_VOICE=Charon
# Vertex AI (service account, BILLED) instead of an API key:
# GEMINI_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/service-account.json

# Claude (Anthropic) — used only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Voice (ElevenLabs) — OPTIONAL ── only for your *cloned* voice ─────────
# Leave empty to use Gemini's free prebuilt voice (above). Fill these only if
# you want voice notes in your own cloned voice (ElevenLabs paid plan + clone):
#   python -m scripts.clone_voice sample.mp3   ->  ELEVENLABS_VOICE_ID=...
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2

# ── Google (Milestone 3) ── from https://console.cloud.google.com ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Working hours (local) used when proposing free calendar slots.
WORK_DAY_START_HOUR=9
WORK_DAY_END_HOUR=18
# Read-only Gmail uses the SAME Google OAuth + the gmail.readonly scope. After
# adding it, re-run `python -m scripts.google_auth` once to refresh the token.
# How many unread inbox messages to surface (on demand / in the morning plan).
GMAIL_MAX_RESULTS=5

# ── Notion (OPTIONAL) ────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations, and a parent
# page id the integration is shared with (Share -> add your integration). The
# bot auto-creates its "Qarorlar"/"Eslatmalar" databases under that page.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# ── Channel digest (Milestone 3) ─────────────────────────────────────────
# How far back the digest looks (hours) and how many posts it shows by default.
DIGEST_WINDOW_HOURS=24
DIGEST_DEFAULT_TOP_N=5
# Local hour the daily digest is delivered automatically (set <0 to disable).
# Disabled: news is shown only via the "Yangiliklar" button, never auto-pushed.
DIGEST_DAILY_HOUR=-1

# ── Daily briefing & review (Joni CEO assistant) ─────────────────────────
# Local hour the morning plan is delivered (set <0 to disable).
MORNING_BRIEFING_HOUR=6
# Local hour the evening day-end review is delivered (set <0 to disable).
EVENING_REVIEW_HOUR=21
# How many days ahead the morning plan surfaces upcoming important dates.
IMPORTANT_DATE_LOOKAHEAD_DAYS=7
# Merge same-topic posts across channels via the LLM (different wording too).
DIGEST_SEMANTIC_DEDUP=true
# On startup, backfill recent history so the digest is not empty after a restart.
DIGEST_BACKFILL_PER_CHANNEL=30
DIGEST_BACKFILL_MAX_CHANNELS=40

# ── Database ─────────────────────────────────────────────────────────────
# Local dev (zero-config, default): sqlite file.
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db
# Production (docker-compose): use Postgres instead, e.g.
# DATABASE_URL=postgresql+asyncpg://assistant:assistant@db:5432/assistant

# ── Security / misc ──────────────────────────────────────────────────────
# Fernet key for the encrypted `secrets` table. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENC_KEY=
USER_TIMEZONE=Asia/Tashkent
LOG_LEVEL=INFO

# Safety: when true, follow-up messages meant for THIRD PARTIES are sent to
# the OWNER instead (so you can test without messaging real people).
TEST_MODE=true

# Userbot rate-limit guards
USERBOT_DAILY_SEND_LIMIT=50
USERBOT_MIN_SECONDS_BETWEEN_SENDS=4
